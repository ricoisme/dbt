{
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "echo \"Session started: $(date)\" >> logs/session.log",
        "windows": "powershell -NoProfile -Command \"Add-Content -Path 'logs/session.log' -Value ('Session started: ' + (Get-Date -Format 'yyyy-MM-dd HH:mm:ss'))\"",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "command": "echo \"User prompt submitted: $(date)\" >> logs/session.log",
       "windows": "powershell -NoProfile -Command \"Add-Content -Path 'logs/session.log' -Value ('User prompt submitted: ' + (Get-Date -Format 'yyyy-MM-dd HH:mm:ss'))\"",
        "cwd": ".",
        "timeoutSec": 30 // default
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "echo \"Session stopped: $(date)\" >> logs/session.log",
         "windows": "powershell -NoProfile -Command \"Add-Content -Path 'logs/session.log' -Value ('Session stopped: ' + (Get-Date -Format 'yyyy-MM-dd HH:mm:ss'))\"",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
